<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- Keep local/dev crashes out of the Crashlytics dashboard. No-op on fdroid,
             which never includes the Crashlytics SDK to read this flag. -->
        <meta-data
            android:name="firebase_crashlytics_collection_enabled"
            android:value="false" />
    </application>

</manifest>
